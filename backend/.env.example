# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/?appName=CMS
DB_NAME=campusfix

# ── SMTP (Gmail) ──────────────────────────────────────────────────────────
# Gmail requires a 16-char App Password, NOT your account password.
# Enable 2-Step Verification, then: Google Account > Security > App passwords.
OUTLOOK_EMAIL=your-address@gmail.com
OUTLOOK_PASSWORD=your-16-char-app-password
OUTLOOK_HOST=smtp.gmail.com
OUTLOOK_PORT=587

# ── Admin accounts (increment the number to add more) ─────────────────────
ADMIN_1_EMAIL=admin@example.com
ADMIN_1_PASSWORD=change-me
ADMIN_1_NAME=Super Admin

# ── Textbee SMS (optional) ────────────────────────────────────────────────
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=
